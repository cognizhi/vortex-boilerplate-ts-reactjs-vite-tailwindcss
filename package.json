{
  "name": "react-ts-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/ensure-generated-files.mjs",
    "build": "tsc --build && vite build",
    "pretypecheck": "node scripts/ensure-generated-files.mjs",
    "typecheck": "tsc --build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "NODE_ENV=test bun --bun vitest run",
    "test:watch": "NODE_ENV=test bun --bun vitest",
    "pretest:e2e": "node scripts/ensure-playwright-browser.mjs",
    "test:e2e": "playwright test",
    "pree2e": "node scripts/ensure-playwright-browser.mjs",
    "e2e": "playwright test",
    "pretest:smoke": "node scripts/ensure-playwright-browser.mjs",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "verify": "bun run lint && bun run typecheck && bun run test",
    "verify:full": "bun run verify && bun run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "nitro": "^3.0.260610-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-svgr": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "~1.50.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.20",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^2.0.0",
    "unplugin-imagemin": "^0.7.0",
    "vite": "^8.1.5",
    "vite-plugin-inspect": "^12.0.2",
    "vitest": "^4.1.10"
  }
}
